<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp">

    <Button
        android:id="@+id/btn_simple_toast"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Simple Toast" />

    <Button
        android:id="@+id/btn_position_toast"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Toast Position (Top)" />

    <Button
        android:id="@+id/btn_custom_toast"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Custom Toast" />

    <Button
        android:id="@+id/btn_snackbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Simple Snackbar" />

</LinearLayout>